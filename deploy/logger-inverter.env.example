# DogHouse INVERTER runtime configuration (second VE.Direct source).
# Install target: /etc/doghouse/logger-inverter.env (mode 0640, owner root:doghouse).
# Models logger.env.example; differs only in the per-device values.

# Identity — required, no defaults. DEVICE_ID carries the device's own serial
# (SER# from the frames) for stable, traceable attribution.
INSTALLATION_ID=bus_hayfork_01
DEVICE_ID=inverter_HQ2136A4M7A
SOURCE_TYPE=inverter
HOSTNAME_TAG=doghouse

# Serial — the INVERTER cable's stable by-id path (NOT a bare ttyUSBN; see
# logger.env.example for why). VE.Direct text protocol is fixed 19200 8N1.
SERIAL_PORT=/dev/serial/by-id/usb-VictronEnergy_BV_VE_Direct_cable_VEAD712P-if00-port0
SERIAL_TIMEOUT_S=2.0
SAMPLE_INTERVAL_S=10

# Local buffer — its OWN file, separate from the MPPT instance's buffer.db.
BUFFER_DB_PATH=/var/lib/doghouse/buffer-inverter.db

# Sync to SOPHIA ingest — same endpoint as the MPPT, but this source's OWN token
# (register a new 'inverter' source: it gets a distinct bearer token).
# The rig exposes the ingest API via Tailscale Serve on :443 (uvicorn is bound to
# 127.0.0.1:8081 behind it); the FastAPI route is /v1/readings. Use the full
# tailnet FQDN so the Serve TLS cert (CN=sophia.tailc63e6b.ts.net) validates.
SYNC_ENDPOINT_URL=https://sophia.tailc63e6b.ts.net/v1/readings
SYNC_INTERVAL_S=60
SYNC_BATCH_SIZE=500
SYNC_TIMEOUT_S=30
SYNC_AUTH_TOKEN=
# Leave empty for normal CA validation (Serve uses Let's Encrypt; the leaf cert
# rotates ~quarterly so pinning it is brittle). Set a SHA-256 leaf fingerprint
# (plain hex) only if you deliberately want pinning.
SYNC_TLS_FINGERPRINT=

# Health + logging — distinct port from the MPPT instance (9100).
HEALTH_PORT=9101
LOG_LEVEL=INFO
