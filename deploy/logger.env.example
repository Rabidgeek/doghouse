# DogHouse runtime configuration.
# Install target: /etc/doghouse/logger.env (mode 0640, owner root:doghouse).

# Identity — required, no defaults.
INSTALLATION_ID=bus_hayfork_01
DEVICE_ID=mppt_100_50_primary
SOURCE_TYPE=solar_mppt
HOSTNAME_TAG=doghouse

# Serial. Use a STABLE /dev/serial/by-id/ path, NOT a bare /dev/ttyUSBN. With
# more than one USB-serial device on the Pi (e.g. an MPPT cable AND an inverter
# cable), ttyUSB enumeration order is not guaranteed across reboots — the cables
# can swap numbers, and this logger would then silently read the wrong device
# and mis-tag its frames. Each VE.Direct cable has a unique serial in its by-id
# name (`ls -l /dev/serial/by-id/`). This is the MPPT (SmartSolar) cable:
SERIAL_PORT=/dev/serial/by-id/usb-VictronEnergy_BV_VE_Direct_cable_VE5GZN4D-if00-port0
SERIAL_TIMEOUT_S=2.0
SAMPLE_INTERVAL_S=10

# Local buffer.
BUFFER_DB_PATH=/var/lib/doghouse/buffer.db

# Sync to SOPHIA ingest. The rig exposes the API via Tailscale Serve on :443
# (uvicorn is bound to 127.0.0.1:8081 behind it); the route is /v1/readings.
# Use the full tailnet FQDN so the Serve TLS cert validates.
SYNC_ENDPOINT_URL=https://sophia.tailc63e6b.ts.net/v1/readings
SYNC_INTERVAL_S=60
SYNC_BATCH_SIZE=500
SYNC_TIMEOUT_S=30
SYNC_AUTH_TOKEN=
# Leave empty to use normal CA validation (Serve uses Let's Encrypt — publicly
# trusted, and the leaf cert rotates ~quarterly so pinning it is brittle). Only
# set a SHA-256 leaf fingerprint (plain hex) if you deliberately want pinning.
SYNC_TLS_FINGERPRINT=

# Health + logging.
HEALTH_PORT=9100
LOG_LEVEL=INFO
